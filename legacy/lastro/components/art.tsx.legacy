/* Código de barras da capa — "esta edição é gratuita" */
export function CodigoDeBarras() {
  const barras = [
    2, 1, 3, 1, 1, 2, 4, 1, 2, 1, 1, 3, 2, 1, 4, 1, 1, 2, 1, 3, 1, 2, 2, 1, 3,
    1, 1, 4, 2, 1, 1, 2, 3, 1, 2, 1,
  ];
  let x = 0;
  return (
    <svg viewBox="0 0 110 32" className="h-10 w-auto" aria-hidden>
      {barras.map((w, i) => {
        const bar = <rect key={i} x={x} y={0} width={w} height={26} fill="currentColor" />;
        x += w + 1.2;
        return bar;
      })}
      <text
        x={x / 2}
        y={32}
        fontSize="5"
        fontFamily="var(--font-fragment)"
        fill="currentColor"
        textAnchor="middle"
      >
        0 000001 000000
      </text>
    </svg>
  );
}

/* Tesoura do cupom de assinatura */
export function Tesoura() {
  return (
    <svg viewBox="0 0 32 20" className="h-5 w-auto" aria-hidden>
      <circle cx="5" cy="5" r="3.2" fill="none" stroke="currentColor" strokeWidth="1" />
      <circle cx="5" cy="15" r="3.2" fill="none" stroke="currentColor" strokeWidth="1" />
      <path d="M8,6.5 L28,13 M8,13.5 L28,7" fill="none" stroke="currentColor" strokeWidth="1" />
    </svg>
  );
}

/* Seta curva de retorno — "o ciclo recomeça" */
