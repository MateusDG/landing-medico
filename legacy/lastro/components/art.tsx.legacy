/* Caderno E — mini tabela de pregão com linha subindo */
export function ArtePregao() {
  return (
    <svg viewBox="0 0 120 72" className="h-16 w-auto" aria-hidden>
      <Draw d="M6,14 h108 M6,34 h108 M6,54 h108" />
      <Draw d="M10,50 L34,44 L58,46 L82,30 L106,20" delay={0.4} />
      <Draw d="M100,20 h6 v6" delay={1} />
