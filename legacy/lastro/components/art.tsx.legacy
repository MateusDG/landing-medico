  return (
    <svg viewBox="0 0 120 72" className="h-16 w-auto" aria-hidden>
      <Draw d="M6,64 h22 v-14 h22 v-14 h22 v-14 h22 v-14" />
      <Draw d="M86,16 h8 v8" delay={0.6} />
      <Draw d="M6,68 h108" delay={0.2} />
    </svg>
  );
}

/* Caderno C — fluxo LEAD → QUALIFICA → AGENDA */
export function ArteFluxo() {
  return (
    <svg viewBox="0 0 200 44" className="h-11 w-auto max-w-full" aria-hidden>
      <Draw d="M2,10 h44 v24 h-44 Z" />
      <Draw d="M50,22 h18 M64,18 l4,4 l-4,4" delay={0.2} />
      <Draw d="M72,10 h62 v24 h-62 Z" delay={0.3} />
      <Draw d="M138,22 h18 M152,18 l4,4 l-4,4" delay={0.5} />
      <Draw d="M160,10 h38 v24 h-38 Z" delay={0.6} />
      <text x="24" y="25.5" fontSize="7.5" fontFamily="var(--font-fragment)" fill="currentColor" textAnchor="middle">LEAD</text>
      <text x="103" y="25.5" fontSize="7.5" fontFamily="var(--font-fragment)" fill="currentColor" textAnchor="middle">QUALIFICA</text>
      <text x="179" y="25.5" fontSize="7.5" fontFamily="var(--font-fragment)" fill="currentColor" textAnchor="middle">AGENDA</text>
    </svg>
  );
}

