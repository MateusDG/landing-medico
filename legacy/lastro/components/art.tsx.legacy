      <Draw d="M112,8 C112,30 8,30 10,16" />
      <Draw d="M6,22 l4,-6 l6,3" delay={0.8} />
    </svg>
  );
}

/* Monograma do expediente — inicial em círculo de filete 1px */
export function Monograma({ inicial }: { inicial: string }) {
  return (
    <svg viewBox="0 0 88 88" className="h-20 w-20" aria-hidden>
      <circle cx="44" cy="44" r="42" fill="none" stroke="currentColor" strokeWidth="1" />
      <text
        x="44"
        y="58"
        fontSize="40"
        fontFamily="var(--font-fraunces)"
        fontWeight="900"
        textAnchor="middle"
        fill="currentColor"
      >
        {inicial}.
      </text>
    </svg>
  );
}
